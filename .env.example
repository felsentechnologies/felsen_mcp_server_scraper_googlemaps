# Docker image name used by Docker/docker-compose.yaml.
IMAGE_NAME=mcp-googlemaps

# Host port published by Docker Compose.
HTTP_PORT=3000

# Global bearer token required by all HTTP routes: /health, /scrape and /mcp.
# Replace this value before deploying. Never commit a real token.
HTTP_BEARER_TOKEN=change-me-generate-a-strong-token

# Backward-compatible fallback token for MCP clients.
# Prefer HTTP_BEARER_TOKEN for new deployments.
MCP_BEARER_TOKEN=

# Comma-separated list of allowed browser origins for /mcp requests.
# Examples:
# MCP_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# MCP_ALLOWED_ORIGINS=*
MCP_ALLOWED_ORIGINS=

# Container timezone.
TZ=America/Sao_Paulo

# Browser executable path used by chromedp inside the Docker image.
CHROME_PATH=/usr/bin/chromium

# Optional browser path fallbacks for local non-Docker runs.
CHROMIUM_PATH=
BROWSER_PATH=

# Optional PostgreSQL connection string. When set, the server migrates and uses
# the dataset database tables automatically. When empty, dataset persistence is ignored.
# Example:
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/dataset?sslmode=disable
DATABASE_URL=
